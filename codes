// 登录弹窗
function openModal(){document.getElementById("loginModal").classList.add("show");}
function closeModal(){document.getElementById("loginModal").classList.remove("show");}
function switchReg(){
  document.getElementById("loginForm").classList.add("hidden");
  document.getElementById("regForm").classList.remove("hidden");
  document.getElementById("modalTitle").innerText = "用户注册";
}
function switchLogin(){
  document.getElementById("loginForm").classList.remove("hidden");
  document.getElementById("regForm").classList.add("hidden");
  document.getElementById("modalTitle").innerText = "用户登录";
}
// 登录
function doLogin(){
  const u = document.getElementById("loginUser").value.trim();
  const p = document.getElementById("loginPwd").value.trim();
  const user = userList.find(x=>x.username===u && x.pwd===p);
  if(!user){alert("账号或密码错误");return;}
  userLogin = u;
  isAdmin = user.role === "admin";
  closeModal();
  refreshUserBar();
  alert("登录成功，欢迎，"+u);
}
// 注册
function doRegister(){
  const u = document.getElementById("regUser").value.trim();
  const p = document.getElementById("regPwd").value.trim();
  const phone = document.getElementById("regPhone").value.trim();
  if(!u||!p||!phone){alert("请填写完整信息");return;}
  if(userList.find(x=>x.username===u)){alert("用户名已存在");return;}
  userList.push({username:u,pwd:p,phone,role:"user"});
  localStorage.setItem("userList",JSON.stringify(userList));
  alert("注册成功，请登录");
  switchLogin();
}
// 刷新顶部用户栏（匹配截图欢迎文字）
function refreshUserBar(){
  const userText = document.getElementById("userText");
  const loginBtn = document.querySelector("#userArea .btn-blue");
  const logoutBtn = document.getElementById("logoutBtn");
  const adminBtn = document.getElementById("adminEntry");
  if(userLogin){
    userText.innerText = `欢迎，${userLogin}`;
    loginBtn.classList.add("hidden");
    logoutBtn.classList.remove("hidden");
    if(isAdmin) adminBtn.classList.remove("hidden");
    else adminBtn.classList.add("hidden");
  }else{
    userText.innerText = "";
    loginBtn.classList.remove("hidden");
    logoutBtn.classList.add("hidden");
    adminBtn.classList.add("hidden");
  }
}
// 退出登录
function logout(){
  userLogin = null;
  isAdmin = false;
  refreshUserBar();
  switchPage("home");
}

// 个人中心切换标签
function switchPersonalTab(tab){
  document.querySelectorAll(".personal-tab").forEach(t=>t.classList.add("hidden"));
  document.getElementById("tab-"+tab).classList.remove("hidden");
  if(tab==="info"){
    const u = userList.find(x=>x.username===userLogin);
