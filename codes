function shipOrder(no){
  const ord = orderData.find(o=>o.orderNo===no);
  ord.status = "shipped";
  localStorage.setItem("orderList",JSON.stringify(orderData));
  renderAdminOrder();
  alert("订单已标记发货");
}
// 评论审核
function renderAdminReview(){
  const box = document.getElementById("adminReviewList");
  const waitReview = reviewData.filter(r=>r.status===0);
  if(waitReview.length===0){box.innerHTML="<p>暂无待审核评论</p>";return;}
  let html = "";
  waitReview.forEach(r=>{
    html += `
      <div class="border p-4 mb-3 flex justify-between items-center">
        <div>用户${r.uid}：${r.content}（${r.star}星）</div>
        <button onclick="passReview(${reviewData.indexOf(r)})" class="btn-green">通过审核</button>
      </div>
    `;
  })
  box.innerHTML = html;
}
// 通过评论
function passReview(idx){
  reviewData[idx].status = 1;
  localStorage.setItem("reviewList",JSON.stringify(reviewData));
  renderAdminReview();
}
